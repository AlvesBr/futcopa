# Supabase — obter em app.supabase.com > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# Usado APENAS em scripts offline (seed_puzzles.ts). Nunca expor no frontend.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# URL canônica do site — usada para metadataBase e OG images em produção
NEXT_PUBLIC_SITE_URL=https://futcopa.vercel.app

# Opcional — para os scripts Python de coleta
# API_FOOTBALL_KEY=<api-football-key>
