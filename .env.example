# WorldCup Pyramid — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores

# ============================================
# Supabase (obrigatório para o jogo funcionar)
# Obter em: https://app.supabase.com → Settings → API
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...sua-anon-key...

# Apenas para scripts de seed (não expor no frontend)
SUPABASE_SERVICE_ROLE_KEY=eyJ...sua-service-role-key...

# ============================================
# API-Football (apenas para scripts Python offline)
# Obter em: https://www.api-football.com → Dashboard
# ============================================
API_FOOTBALL_KEY=sua-chave-aqui

# ============================================
# App
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
